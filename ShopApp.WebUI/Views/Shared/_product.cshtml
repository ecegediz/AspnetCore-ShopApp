@model Product

<div class="col-md-4 mb-4">
    <div class="card mb-3">
        <img class="card-img-top" src="/img/@Model.ImageUrl" alt="@Model.Name" />

        <div class="card-body">
            <h5 class="card-title">
                <a href="#">@Model.Name</a>
            </h5>
            <p class="card-text text-muted">
                <i class="fa-solid fa-turkish-lira-sign"></i> @Model.Price
            </p>
        </div>

        <div class="card-footer text-center">
            <a asp-controller="Shop" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm">Details</a>
            <a href="#" class="btn btn-outline-primary btn-sm">Add To Cart</a>
        </div>
    </div>
</div>